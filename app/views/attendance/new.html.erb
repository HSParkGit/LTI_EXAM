<div class="attendance-form-container">
  <div class="form-header">
    <h1>Create Attendance Session</h1>
    <% if @course_title.present? %>
      <p class="course-name"><%= @course_title %></p>
    <% end %>
  </div>

  <% if flash[:error] %>
    <div class="alert alert-danger"><%= flash[:error] %></div>
  <% end %>

  <% if @session.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @session.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render 'form', url: attendance_index_path %>
</div>

<style>
  .attendance-form-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .form-header {
    padding: 20px 0;
  }

  .form-header h1 {
    font-size: 26px;
    font-weight: 500;
    margin: 0 0 0.25rem 0;
    color: #212529;
  }

  .course-name {
    font-size: 0.875rem;
    color: #6c757d;
    margin: 0;
  }

  .form-card {
    background: #fff;
    border: 1px solid #c7cdd1;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .form-section {
    margin-bottom: 2rem;
  }

  .form-section-title {
    font-size: 1rem;
    font-weight: 600;
    color: #212529;
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e9ecef;
  }

  .setting-section {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 1rem;
  }

  .form-row {
    display: flex;
    margin-bottom: 16px;
  }

  .form-column-left {
    width: 150px;
    padding-right: 20px;
    padding-top: 8px;
  }

  .form-column-left label {
    font-weight: 600;
    color: #2d3b45;
    font-size: 14px;
  }

  .required {
    color: #dc3545;
  }

  .form-column-right {
    flex: 1;
  }

  .input-full {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
  }

  .input-small {
    width: 100px;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
  }

  .input-datetime {
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
  }

  .input-full:focus, .input-small:focus, .input-datetime:focus {
    outline: none;
    border-color: #0374B5;
    box-shadow: 0 0 0 2px rgba(3, 116, 181, 0.2);
  }

  .form-select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    background-color: white;
  }

  .hint-text {
    font-size: 12px;
    color: #6c757d;
    margin-top: 6px;
    margin-bottom: 0;
  }

  .hint-inline {
    font-size: 14px;
    color: #6c757d;
    margin-left: 8px;
  }

  .radio-group {
    display: flex;
    gap: 2rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
  }

  .checkbox-group {
    margin-bottom: 8px;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #e9ecef;
  }

  .btn-cancel {
    background-color: transparent;
    color: #6c757d;
    border: 1px solid #c7cdd1;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-cancel:hover {
    background-color: #f8f9fa;
    color: #6c757d;
  }

  .btn-primary {
    background-color: #0374B5;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-primary:hover {
    background-color: #025a8c;
  }

  .alert {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .alert-danger {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
  }

  .alert-danger ul {
    margin: 0;
    padding-left: 1.5rem;
  }
</style>
