<!-- Student Detail Modal -->
<div id="studentDetailModal" class="sd-modal-overlay" style="display:none;">
  <div class="sd-modal">
    <div class="sd-modal-header">
      <div class="sd-student-info">
        <div class="sd-avatar" id="sdAvatar">?</div>
        <div>
          <h2 class="sd-student-name" id="sdStudentName">-</h2>
          <span class="sd-student-id" id="sdStudentId">-</span>
        </div>
      </div>
      <button class="sd-modal-close" id="sdModalClose">&times;</button>
    </div>

    <div class="sd-stats-row" id="sdStatsRow">
      <div class="sd-stat"><span class="sd-stat-icon icon-present">●</span> <%= t('attendance.present') %> <strong id="sdPresent">0</strong></div>
      <div class="sd-stat"><span class="sd-stat-icon icon-late">▲</span> <%= t('attendance.late') %> <strong id="sdLate">0</strong></div>
      <div class="sd-stat"><span class="sd-stat-icon icon-absent">✕</span> <%= t('attendance.absent') %> <strong id="sdAbsent">0</strong></div>
      <div class="sd-stat"><span class="sd-stat-icon icon-pending">—</span> <%= t('attendance.pending') %> <strong id="sdPending">0</strong></div>
    </div>

    <div class="sd-modal-body" id="sdModalBody">
      <div class="sd-loading" id="sdLoading">Loading...</div>
      <table class="sd-table" id="sdTable" style="display:none;">
        <thead>
          <tr>
            <th><%= t('attendance.week') %></th>
            <th><%= t('attendance.lesson') %></th>
            <th><%= t('attendance.lesson_attendance') %></th>
            <th><%= t('attendance.lecture_title') %></th>
            <th><%= t('attendance.type') %></th>
            <th><%= t('attendance.start_end') %></th>
            <th><%= t('attendance.due_date') %></th>
            <th><%= t('attendance.attendance_status') %></th>
          </tr>
        </thead>
        <tbody id="sdTableBody"></tbody>
      </table>
      <div class="sd-empty" id="sdEmpty" style="display:none;">No attendance records found.</div>
    </div>

    <div class="sd-modal-footer">
      <button class="sd-btn-close" id="sdBtnClose"><%= t('attendance.close') %></button>
    </div>
  </div>
</div>

<style>
  .sd-modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.4); z-index: 900;
    display: flex; align-items: center; justify-content: center;
  }
  .sd-modal {
    background: white; border-radius: 12px;
    width: 94%; max-width: 960px; max-height: 80vh;
    display: flex; flex-direction: column;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .sd-modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.25rem 1.5rem;
  }
  .sd-student-info { display: flex; align-items: center; gap: 0.875rem; }
  .sd-avatar {
    width: 44px; height: 44px; border-radius: 50%; background: #e9ecef;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.125rem; font-weight: 600; color: #495057;
  }
  .sd-student-name { font-size: 1.125rem; font-weight: 600; color: #212529; margin: 0; }
  .sd-student-id { font-size: 0.75rem; color: #6c757d; }
  .sd-modal-close {
    background: none; border: none; font-size: 1.5rem; color: #6c757d;
    cursor: pointer; padding: 0; line-height: 1;
  }
  .sd-modal-close:hover { color: #212529; }

  .sd-stats-row {
    display: flex; gap: 1rem; padding: 0 1.5rem 0.75rem;
  }
  .sd-stat {
    display: flex; align-items: center; gap: 0.375rem;
    font-size: 0.8125rem; font-weight: 500; color: #495057;
  }
  .sd-stat strong { color: #212529; }
  .sd-stat-icon { font-size: 0.6875rem; }
  .icon-present { color: #1E7B1E; }
  .icon-late { color: #FF6A33; }
  .icon-absent { color: #CD0404; }
  .icon-pending { color: #8A8A8A; }

  .sd-modal-body {
    flex: 1; overflow-y: auto;
    border-top: 1px solid #e9ecef; border-bottom: 1px solid #e9ecef;
    min-height: 200px;
  }
  .sd-loading, .sd-empty {
    display: flex; align-items: center; justify-content: center;
    padding: 3rem; color: #6c757d; font-size: 0.875rem;
  }

  .sd-table { width: 100%; border-collapse: collapse; }
  .sd-table thead { position: sticky; top: 0; z-index: 1; }
  .sd-table th {
    padding: 0.625rem 0.75rem; text-align: center;
    background-color: #f2f2f3; font-weight: 500; font-size: 0.75rem;
    color: #212529; white-space: nowrap;
  }
  .sd-table td {
    padding: 0.625rem 0.75rem; text-align: center;
    font-size: 0.8125rem; color: #212529; font-weight: 500;
  }
  .sd-td-week { font-weight: 600; border-bottom: 2px solid #d1d5db; }
  .sd-td-lesson { font-weight: 600; color: #495057; border-left: 1.5px solid #e9ecef; }
  .sd-td-title { text-align: left; }
  .sd-td-time { color: #6c757d; font-size: 0.75rem; white-space: nowrap; }
  .sd-border-week { border-bottom: 2px solid #d1d5db; }
  .sd-border-lesson { border-bottom: 1.5px solid #e9ecef; }

  .sd-status-icon { font-size: 0.875rem; }
  .sd-status-icon.opacity-low { opacity: 0.35; }

  .sd-modal-footer {
    display: flex; justify-content: center; padding: 0.875rem 1.5rem;
  }
  .sd-btn-close {
    padding: 0.5rem 3rem; border-radius: 6px; font-size: 0.875rem;
    font-weight: 600; cursor: pointer; border: none;
    background-color: #e9ecef; color: #495057;
  }
  .sd-btn-close:hover { background-color: #dee2e6; }
</style>

<script>
(function() {
  var modal = document.getElementById('studentDetailModal');
  var loading = document.getElementById('sdLoading');
  var table = document.getElementById('sdTable');
  var tableBody = document.getElementById('sdTableBody');
  var emptyState = document.getElementById('sdEmpty');

  var statusIcons = { present: '●', excused: '●', late: '▲', absent: '✕', pending: '—' };

  function getStatusIcon(status) {
    return statusIcons[status] || '—';
  }

  window.openStudentDetailModal = function(studentId) {
    modal.style.display = 'flex';
    loading.style.display = 'flex';
    table.style.display = 'none';
    emptyState.style.display = 'none';

    var url = '/attendance/student_detail?student_identifier=' + encodeURIComponent(studentId);
    fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loading.style.display = 'none';

        if (!data.success) {
          emptyState.textContent = data.error || 'Failed to load.';
          emptyState.style.display = 'flex';
          return;
        }

        // Header
        document.getElementById('sdStudentName').textContent = data.student_name || studentId;
        document.getElementById('sdStudentId').textContent = data.student_identifier || '';
        document.getElementById('sdAvatar').textContent = (data.student_name || '?')[0].toUpperCase();

        // Stats
        var stats = data.stats || {};
        document.getElementById('sdPresent').textContent = stats.present || 0;
        document.getElementById('sdLate').textContent = stats.late || 0;
        document.getElementById('sdAbsent').textContent = stats.absent || 0;
        document.getElementById('sdPending').textContent = stats.pending || 0;

        var processed = data.processed_data || [];
        if (processed.length === 0) {
          emptyState.style.display = 'flex';
          return;
        }

        // Render table
        renderDetailTable(processed);
        table.style.display = 'table';
      })
      .catch(function(err) {
        loading.style.display = 'none';
        emptyState.textContent = 'Error loading data.';
        emptyState.style.display = 'flex';
        console.error('Student detail fetch error:', err);
      });
  };

  function renderDetailTable(processedData) {
    var html = '';

    processedData.forEach(function(weekGroup) {
      var week = weekGroup.week;
      var lessons = weekGroup.lessons || [];
      var totalWeekLectures = 0;
      lessons.forEach(function(l) { totalWeekLectures += (l.lectures || []).length; });

      var weekLectureIdx = 0;
      lessons.forEach(function(lesson, lessonIdx) {
        var lectures = lesson.lectures || [];
        var lectureCount = lectures.length;
        var isLastLesson = lessonIdx === lessons.length - 1;
        var rowspanBorder = isLastLesson ? 'sd-border-week' : 'sd-border-lesson';

        lectures.forEach(function(lec, lecIdx) {
          var isFirstOfWeek = weekLectureIdx === 0;
          var isFirstOfLesson = lecIdx === 0;
          var isLastOfWeek = weekLectureIdx === totalWeekLectures - 1;
          var isLastOfLesson = lecIdx === lectureCount - 1;
          var cellBorder = '';
          if (isLastOfLesson) {
            cellBorder = isLastOfWeek ? 'sd-border-week' : 'sd-border-lesson';
          }

          html += '<tr>';

          if (isFirstOfWeek) {
            html += '<td class="sd-td-week sd-border-week" rowspan="' + totalWeekLectures + '">Week ' + week + '</td>';
          }
          if (isFirstOfLesson) {
            html += '<td class="sd-td-lesson ' + rowspanBorder + '" rowspan="' + lectureCount + '">Lesson ' + lesson.lesson_id + '</td>';
            html += '<td class="' + rowspanBorder + '" rowspan="' + lectureCount + '"><span class="sd-status-icon icon-' + lesson.lesson_status + '">' + getStatusIcon(lesson.lesson_status) + '</span></td>';
          }

          html += '<td class="sd-td-title ' + cellBorder + '">' + (lec.title || '-') + '</td>';

          html += '<td class="' + cellBorder + '">' + (lec.attendance_type || '-').toUpperCase() + '</td>';
          html += '<td class="sd-td-time ' + cellBorder + '">' + (lec.class_time || '-') + '</td>';
          html += '<td class="sd-td-time ' + cellBorder + '">' + (lec.due || '-') + '</td>';
          html += '<td class="' + cellBorder + '"><span class="sd-status-icon icon-' + lec.status + ' opacity-low">' + getStatusIcon(lec.status) + '</span></td>';

          html += '</tr>';
          weekLectureIdx++;
        });
      });
    });

    tableBody.innerHTML = html;
  }

  function closeModal() { modal.style.display = 'none'; }

  document.getElementById('sdModalClose').addEventListener('click', closeModal);
  document.getElementById('sdBtnClose').addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });
})();
</script>
