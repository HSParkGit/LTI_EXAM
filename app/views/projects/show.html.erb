<div class="project-show-container">
  <div class="project-header">
    <div class="project-header-content">
      <h1><%= @project_data[:name] %></h1>
      <div class="project-header-actions">
        <%= link_to '← 목록으로', projects_path, class: 'btn-back' %>
        <% if instructor?(@user_role) %>
          <%= link_to '수정', edit_project_path(@project), class: 'btn-edit' %>
          <%= button_to '삭제', project_path(@project), 
              method: :delete, 
              data: { confirm: '정말 삭제하시겠습니까?', turbo: false }, 
              class: 'btn-delete',
              form: { style: 'display: inline;' } %>
        <% end %>
      </div>
    </div>
  </div>
  
  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>
  
  <% if flash[:error] %>
    <div class="alert alert-danger"><%= flash[:error] %></div>
  <% end %>
  
  <!-- 프로젝트 정보 카드 -->
  <% if @project_data[:assignments].present? && @project_data[:assignments].any? %>
    <div class="project-info-card">
      <div class="project-info-content">
        <div class="info-row">
          <span class="info-label">Group Assignment</span>
          <span class="info-value">This is a Group Assignment</span>
        </div>
        <% first_assignment = @project_data[:assignments].first %>
        <% if first_assignment && first_assignment['group_category_id'].present? %>
          <div class="info-row">
            <span class="info-label">Group Set</span>
            <span class="info-value"><%= first_assignment['group_category_name'] || first_assignment['group_category_id'] %></span>
          </div>
        <% end %>
      </div>
      
      <!-- Step Navigator -->
      <% if @project_data[:assignments].present? && @project_data[:assignments].any? %>
        <div class="step-navigator-section">
          <h3 class="step-navigator-title">Step Navigator</h3>
          <div class="step-navigator-container">
            <% @project_data[:assignments].each_with_index do |assignment, index| %>
              <% nav_step_status = get_step_status(assignment) %>
              <% text_color = case nav_step_status
                  when 'past' then '#6B7280'
                  when 'upcoming' then '#9CA3AF'
                  else '#1F2937'
                  end %>
              <div class="step-navigator-item" 
                   data-step-index="<%= index %>"
                   onclick="scrollToStep(<%= index %>)">
                <div class="step-navigator-title-text" style="color: <%= text_color %>">
                  Step <%= index + 1 %> <%= assignment['name'] || 'Untitled Assignment' %>
                </div>
                <% if assignment['due_at'].present? %>
                  <div class="step-navigator-date" style="color: <%= text_color %>">
                    <div style="display: flex;">
                      <span style="width: 84px;">Due</span>
                      <span style="width: 70px;"><%= format_date_navigator(assignment['due_at'])[0] %></span>
                      <span style="margin-left: 8px; width: 60px;"><%= format_date_navigator(assignment['due_at'])[1] %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
  
  <!-- STEP 목록 -->
  <% if @project_data[:assignments].present? && @project_data[:assignments].any? %>
    <div class="steps-container">
      <% @project_data[:assignments].each_with_index do |assignment, index| %>
        <% step_status = get_step_status(assignment) %>
        <div class="step-card step-<%= step_status %>" id="step-<%= index %>">
          <!-- Step Header (Canvas 스타일) -->
          <div class="step-header-canvas">
            <h1 class="step-title-canvas">
              Step <%= index + 1 %>: <%= assignment['name'] || 'Untitled Assignment' %>
            </h1>
            <% if instructor?(@user_role) && @groups.present? && @groups.any? %>
              <div class="step-group-selector">
                <label class="group-select-label">Select Group:</label>
                <select class="group-select-dropdown" id="group-select-<%= index %>">
                  <% @groups.each do |group| %>
                    <option value="<%= group['id'] || group[:id] %>">
                      <%= group['name'] || group[:name] %>
                    </option>
                  <% end %>
                </select>
              </div>
            <% end %>
          </div>
          
          <!-- Step 상세 카드 (Canvas 스타일) -->
          <div class="step-detail-card">
            <!-- Step Description -->
            <div class="step-description-canvas">
              <div class="step-description-box">
                <% if assignment['description'].present? %>
                  <div class="step-description-content">
                    <%= raw assignment['description'] %>
                  </div>
                <% else %>
                  <p class="step-description-empty">No description provided.</p>
                <% end %>
              </div>
            </div>
            
            <!-- Step 상세 정보 (Canvas 스타일) -->
            <div class="step-info-list">
              <div class="step-info-item">
                <span class="step-info-label">Points:</span>
                <span class="step-info-value"><%= assignment['points_possible'] || 'N/A' %></span>
              </div>
              <% if instructor?(@user_role) %>
                <% if assignment['grade_group_students_individually'] %>
                  <div class="step-info-item">
                    <span class="step-info-label">Grades Assignment</span>
                    <span class="step-info-value">Assign Grades to Each Student Individually</span>
                  </div>
                <% end %>
                <div class="step-info-item">
                  <span class="step-info-label">Submitting</span>
                  <span class="step-info-value"><%= Array(assignment['submission_types']).join(', ') || 'N/A' %></span>
                </div>
                <div class="step-info-item">
                  <span class="step-info-label">Allowed Attempts</span>
                  <span class="step-info-value"><%= assignment['allowed_attempts'] || '1' %></span>
                </div>
              <% else %>
                <% if assignment['due_at'].present? %>
                  <div class="step-info-item">
                    <span class="step-info-label">Due:</span>
                    <span class="step-info-value"><%= format_date_navigator(assignment['due_at']).join(' ') %></span>
                  </div>
                <% end %>
                <% if assignment['unlock_at'].present? %>
                  <div class="step-info-item">
                    <span class="step-info-label">Available:</span>
                    <span class="step-info-value"><%= format_date_navigator(assignment['unlock_at']).join(' ') %></span>
                  </div>
                <% end %>
                <div class="step-info-item">
                  <span class="step-info-label">Submitting:</span>
                  <span class="step-info-value"><%= Array(assignment['submission_types']).join(', ') || 'N/A' %></span>
                </div>
                <% if assignment['allowed_extensions'].present? %>
                  <div class="step-info-item">
                    <span class="step-info-label">File Types:</span>
                    <span class="step-info-value"><%= Array(assignment['allowed_extensions']).join(', ') || 'N/A' %></span>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
          
          <!-- Instructor Evaluations (Canvas 스타일) -->
          <% if instructor?(@user_role) %>
            <section class="evaluations-section">
              <div class="evaluations-header">
                <strong class="evaluations-title">Evaluations</strong>
                <div class="evaluations-actions">
                  <button 
                    type="button" 
                    class="evaluations-peer-review-btn <%= assignment['peer_reviews'] ? 'btn-primary' : 'btn-secondary' %>"
                    <%= assignment['peer_reviews'] ? '' : 'disabled' %>
                    onclick="window.open('<%= @canvas_url %>/courses/<%= @lti_context.canvas_course_id %>/assignments/<%= assignment['id'] %>/peer_reviews', '_blank')"
                    style="cursor: <%= assignment['peer_reviews'] ? 'pointer' : 'not-allowed' %>">
                    Assign Peer Review
                  </button>
                </div>
              </div>
              
              <!-- Group Members 통계 -->
              <% group_submissions = assignment['group_submissions'] || [] %>
              <% completed_count = group_submissions.count { |s| s['submission']&.dig('published_score') != nil } %>
              <div class="evaluations-group-info">
                <img src="/images/project/icon_evaluations_arrow.svg" alt="" class="evaluations-arrow-icon" />
                <span class="evaluations-group-text">
                  Group Members{' '}
                  <span class="evaluations-complete-count">
                    <%= completed_count %>/<%= group_submissions.length %> Complete
                  </span>
                </span>
              </div>
              
              <!-- 그룹 멤버별 제출 상태 -->
              <div class="evaluations-list">
                <% if group_submissions.any? %>
                  <% group_submissions.each_with_index do |item, idx| %>
                    <% submission = item['submission'] || {} %>
                    <% workflow_state = submission['workflow_state'] || 'unsubmitted' %>
                    <% user_id = submission['user_id'] %>
                    <% user_name = item['user_name'] || "Student #{user_id}" %>
                    <div class="evaluations-item">
                      <div class="evaluations-item-content">
                        <span class="evaluations-item-left">
                          <span class="evaluations-item-number"><%= idx + 1 %></span>
                          <span class="evaluations-item-name"><%= user_name %></span>
                        </span>
                        <div class="evaluations-item-status">
                          <% if workflow_state == 'graded' %>
                            <div class="evaluations-status-graded">
                              <img src="/images/project/icon_group_check.svg" alt="check" class="evaluations-check-icon" />
                              <span>Graded</span>
                            </div>
                          <% elsif workflow_state == 'submitted' %>
                            <div class="evaluations-status-submitted">Submitted</div>
                          <% else %>
                            <div class="evaluations-status-not-yet">Not Yet</div>
                          <% end %>
                        </div>
                        <a href="<%= speed_grader_url(@lti_context.canvas_course_id, assignment['id'], @canvas_url) %>&student_id=<%= user_id %>" target="_blank" rel="noopener noreferrer">
                          <button class="evaluations-button <%= submission['published_score'] != nil ? 'btn-outlined' : 'btn-primary' %>">
                            <%= submission['published_score'] != nil ? 'Revaluation' : 'Evaluations' %>
                          </button>
                        </a>
                      </div>
                    </div>
                  <% end %>
                <% else %>
                  <div class="evaluations-empty">
                    <p>No group members found.</p>
                  </div>
                <% end %>
              </div>
            </section>
          <% else %>
            <!-- Student Submission Phase (Canvas 스타일) -->
            <section class="submission-phase-section">
              <header class="submission-phase-header">
                <img src="/images/project/icon_submission.svg" alt="Submission phase icon" class="submission-phase-icon" />
                <h2 class="submission-phase-title">Submission Phase</h2>
              </header>
              <div class="submission-phase-grid">
                <!-- 1. Submit -->
                <div class="submission-phase-card">
                  <article class="submission-phase-card-content submission-phase-card-submit">
                    <div class="submission-phase-card-header">
                      <div class="submission-phase-card-title-section">
                        <h3 class="submission-phase-card-title">1. submit</h3>
                        <% if assignment['due_at'].present? %>
                          <p class="submission-phase-card-due">Due: <%= format_date_navigator(assignment['due_at']).join(' ') %></p>
                        <% end %>
                      </div>
                      <img src="/images/project/icon_submission.svg" alt="Submit task icon" class="submission-phase-card-icon" />
                    </div>
                    <div class="submission-phase-card-body">
                      <div class="submission-phase-card-button-wrapper">
                        <% if assignment['is_submitted'] %>
                          <% submission_attempts = assignment['submission_attempts'] || assignment['submission']&.dig('attempt') || 1 %>
                          <button class="submission-phase-button submission-phase-button-resubmit" 
                                  onclick="window.open('<%= canvas_assignment_url(@lti_context.canvas_course_id, assignment['id'], @canvas_url) %>', '_blank')">
                            Resubmit (<%= submission_attempts %> attempts)
                          </button>
                          <% submitted_at = assignment['submitted_at'] || assignment['submission']&.dig('submitted_at') %>
                          <% if submitted_at.present? %>
                            <div class="submission-phase-submitted-info">
                              <span>Submitted: <%= format_date_navigator(submitted_at).join(' ') %></span>
                            </div>
                          <% end %>
                        <% else %>
                          <button class="submission-phase-button submission-phase-button-submit" 
                                  onclick="window.open('<%= canvas_assignment_url(@lti_context.canvas_course_id, assignment['id'], @canvas_url) %>', '_blank')">
                            Submit
                          </button>
                        <% end %>
                        <p class="submission-phase-refresh-note">Please refresh the page after submitting your assignment.</p>
                      </div>
                    </div>
                  </article>
                </div>
                
                <!-- 2. Review (Peer Review, 조건부) -->
                <% if assignment['peer_reviews'] %>
                  <div class="submission-phase-card">
                    <article class="submission-phase-card-content submission-phase-card-review">
                      <div class="submission-phase-card-header">
                        <div class="submission-phase-card-title-section">
                          <h3 class="submission-phase-card-title">2. Review</h3>
                          <% if assignment['peer_reviews_due_at'].present? || assignment['lock_at'].present? %>
                            <p class="submission-phase-card-due">Until: <%= format_date_navigator(assignment['peer_reviews_due_at'] || assignment['lock_at']).join(' ') %></p>
                          <% end %>
                        </div>
                        <img src="/images/project/icon_review.svg" alt="Review task icon" class="submission-phase-card-icon" />
                      </div>
                      <div class="submission-phase-card-body">
                        <% if assignment['is_submitted'] %>
                          <div class="submission-phase-card-button-wrapper">
                            <button class="submission-phase-button submission-phase-button-review" 
                                    onclick="window.open('<%= canvas_assignment_url(@lti_context.canvas_course_id, assignment['id'], @canvas_url) %>', '_blank')">
                              Peer Review
                            </button>
                          </div>
                        <% else %>
                          <div class="submission-phase-locked">
                            <img src="/images/project/icon_lock.svg" alt="Unlock icon" class="submission-phase-lock-icon" />
                            <p>unlocks <%= format_date_navigator(assignment['peer_reviews_due_at'] || assignment['lock_at']).join(' ') %></p>
                          </div>
                        <% end %>
                      </div>
                    </article>
                  </div>
                <% end %>
                
                <!-- 3. Feedback -->
                <div class="submission-phase-card">
                  <article class="submission-phase-card-content submission-phase-card-feedback">
                    <div class="submission-phase-card-header">
                      <div class="submission-phase-card-title-section">
                        <h3 class="submission-phase-card-title">3. Feedback</h3>
                      </div>
                      <img src="/images/project/icon_feedback.svg" alt="Feedback task icon" class="submission-phase-card-icon" />
                    </div>
                    <div class="submission-phase-card-body">
                      <div class="submission-phase-card-button-wrapper">
                        <% is_submitted_or_graded = assignment['is_submitted'] || assignment['submission']&.dig('workflow_state') == 'submitted' || assignment['submission']&.dig('workflow_state') == 'graded' %>
                        <% if is_submitted_or_graded %>
                          <button class="submission-phase-button submission-phase-button-view" 
                                  onclick="window.open('<%= canvas_submission_url(@lti_context.canvas_course_id, assignment['id'], @lti_claims[:canvas_user_id] || @lti_claims["canvas_user_id"], @canvas_url) %>', '_blank')">
                            View Submission
                          </button>
                          <div class="submission-phase-feedback-status">
                            <% workflow_state = assignment['submission']&.dig('workflow_state') || (assignment['is_graded'] ? 'graded' : 'submitted') %>
                            <% if workflow_state == 'graded' %>
                              <% graded_at = assignment['graded_at'] || assignment['submission']&.dig('graded_at') %>
                              <p>Feedback received: <%= graded_at ? format_date_navigator(graded_at).join(' ') : '-' %></p>
                            <% else %>
                              <p>Awaiting Reviews</p>
                            <% end %>
                          </div>
                        <% else %>
                          <button class="submission-phase-button submission-phase-button-disabled" disabled>
                            View Submission
                          </button>
                          <div class="submission-phase-feedback-status">
                            <p>Awaiting Reviews</p>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </article>
                </div>
              </div>
            </section>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p>과제가 없습니다.</p>
    </div>
  <% end %>
</div>

<style>
  .project-show-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }
  
  /* 프로젝트 정보 카드 */
  .project-info-card {
    background-color: white;
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
  }
  
  .project-info-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 12px;
    color: #4B5563;
  }
  
  .info-row {
    display: flex;
  }
  
  .info-label {
    font-weight: 500;
    width: 120px;
  }
  
  .info-value {
    flex: 1;
  }
  
  /* Step Navigator */
  .step-navigator-section {
    margin-top: 20px;
    margin-bottom: 20px;
  }
  
  .step-navigator-title {
    font-size: 16px;
    font-weight: 600;
    color: #1F2937;
    margin-bottom: 12px;
  }
  
  .step-navigator-container {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: #E0E0E0 transparent;
  }
  
  .step-navigator-container::-webkit-scrollbar {
    height: 8px;
  }
  
  .step-navigator-container::-webkit-scrollbar-track {
    background: transparent;
  }
  
  .step-navigator-container::-webkit-scrollbar-thumb {
    background-color: #E0E0E0;
    border-radius: 4px;
  }
  
  .step-navigator-item {
    display: flex;
    flex-direction: column;
    padding: 12px;
    border-radius: 12px;
    min-width: 200px;
    flex-shrink: 0;
    cursor: pointer;
    transition: all 0.15s ease-in-out;
    border: 1px solid #E5E7EB;
    background-color: white;
  }
  
  .step-navigator-item:hover {
    border-color: #3B82F6;
  }
  
  .step-navigator-title-text {
    font-weight: 500;
    font-size: 14px;
    margin-bottom: 8px;
  }
  
  .step-navigator-date {
    font-size: 11px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  
  .step-navigator-date span:first-child {
    width: 84px;
  }
  
  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e9ecef;
  }
  
  .project-header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .project-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #212529;
    margin: 0;
  }
  
  .project-header-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  
  .btn-back {
    padding: 0.5rem 1rem;
    color: #6c757d;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }
  
  .btn-back:hover {
    color: #212529;
  }
  
  .btn-edit {
    padding: 0.5rem 1.25rem;
    background-color: #0626a9;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 0.2s;
  }
  
  .btn-edit:hover {
    background-color: #051d8a;
    color: white;
  }
  
  .btn-delete {
    padding: 0.5rem 1.25rem;
    background-color: #dc3545;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  
  .btn-delete:hover {
    background-color: #bb2d3b;
  }
  
  .steps-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .step-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  /* Step Header (Canvas 스타일) */
  .step-header-canvas {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .step-title-canvas {
    font-size: 24px;
    font-weight: bold;
    color: #1F2937;
    margin: 0;
  }
  
  .step-group-selector {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .group-select-label {
    font-size: 14px;
    font-weight: 500;
    color: #4B5563;
  }
  
  .group-select-dropdown {
    padding: 6px 12px;
    border: 1px solid #d0d1d7;
    border-radius: 4px;
    font-size: 14px;
    background-color: white;
    cursor: pointer;
  }
  
  .group-select-dropdown:focus {
    outline: none;
    border-color: #0626a9;
  }
  
  /* Step 상세 카드 (Canvas 스타일) */
  .step-detail-card {
    background-color: white;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    padding: 20px;
    min-height: 420px;
  }
  
  /* Step Description (Canvas 스타일) */
  .step-description-canvas {
    margin-bottom: 20px;
  }
  
  .step-description-box {
    font-size: 12px;
    color: #9CA3AF;
    word-break: break-words;
    height: 200px;
    overflow-y: auto;
    border: 1px solid rgba(173, 184, 192, 0.4);
    border-radius: 8px;
    padding: 12px;
  }
  
  .step-description-content {
    line-height: 1.6;
  }
  
  .step-description-empty {
    margin: 0;
    color: #9CA3AF;
  }
  
  /* Step 상세 정보 (Canvas 스타일) */
  .step-info-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 12px;
  }
  
  .step-info-item {
    display: flex;
  }
  
  .step-info-label {
    font-weight: 500;
    width: 120px;
    color: #4B5563;
  }
  
  .step-info-value {
    flex: 1;
    color: #1F2937;
  }
  
  /* Submission Phase (학생용, Canvas 스타일) */
  .submission-phase-section {
    padding: 20px;
    background-color: white;
    border-radius: 8px;
    margin-bottom: 20px;
  }
  
  .submission-phase-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  
  .submission-phase-icon {
    width: 24px;
    height: 24px;
  }
  
  .submission-phase-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0;
    color: #1F2937;
  }
  
  .submission-phase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    width: 100%;
  }
  
  .submission-phase-card {
    display: flex;
    flex-direction: column;
  }
  
