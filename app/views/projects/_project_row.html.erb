<tr>
  <!-- Project Name Column -->
  <td class="project-name-cell">
    <div class="project-name-row">
      <div class="project-name-content">
        <%= link_to project[:name], project_path(project[:id]), class: 'project-name-link' %>
        <div class="project-date-info">
          Start - - Due 
          <% if project[:assignments].present? && project[:assignments].any? %>
            <% first_due = project[:assignments].find { |a| a['due_at'].present? } %>
            <% if first_due %>
              <%= format_date(first_due['due_at']) %>
            <% else %>
              -
            <% end %>
          <% else %>
            -
          <% end %>
          / End -
        </div>
      </div>
      <!-- More Actions Menu (드롭다운) - Instructor만 표시 -->
      <% if @user_role == :instructor %>
        <div class="project-actions-menu">
          <button type="button" class="btn-more" onclick="toggleProjectMenu(<%= project[:id] %>)">
            <span class="more-icon">⋮</span>
          </button>
          <div id="project-menu-<%= project[:id] %>" class="dropdown-menu">
            <%= link_to '수정', edit_project_path(project[:id]), class: 'dropdown-item' %>
            <%= button_to '삭제', project_path(project[:id]),
                method: :delete,
                data: { confirm: '정말 삭제하시겠습니까?', turbo: false },
                class: 'dropdown-item-danger',
                form: { class: 'dropdown-item-form', style: 'margin: 0; padding: 0; display: block;' } %>
          </div>
        </div>
      <% end %>
    </div>
  </td>
  
  <!-- STEP Columns -->
  <% (1..max_steps).each do |step_num| %>
    <% assignment = project[:assignments]&.[](step_num - 1) %>
    <td class="step-cell">
      <% if assignment %>
        <% step_status = get_step_status(assignment) %>
        <div class="step-content">
          <% if assignment['due_at'].present? %>
            <div class="step-due-date">
              Due <%= format_date(assignment['due_at']) %>
            </div>
          <% end %>
          <div class="step-badges">
            <!-- Status Badge -->
            <span class="badge badge-<%= step_status %>">
              <%= case step_status
                  when 'past' then 'Past'
                  when 'current' then 'Current'
                  when 'upcoming' then 'Upcoming'
                  else 'Empty'
                  end %>
            </span>
            
            <!-- Instructor: Grading Status -->
            <% if @user_role == :instructor %>
              <% if (assignment['grading_required'] || 0) > 0 %>
                <span class="badge badge-needs-grading">
                  Needs Grading
                </span>
              <% elsif (assignment['graded_count'] || 0) > 0 && (assignment['submitted_count'] || 0) > 0 %>
                <span class="badge badge-submitted">
                  Graded: <%= assignment['graded_count'] %>/<%= assignment['submitted_count'] %>
                </span>
              <% end %>
            <% else %>
              <!-- Student: Submission Status -->
              <% if assignment['is_submitted'] %>
                <span class="badge badge-submitted">제출 완료</span>
              <% else %>
                <span class="badge badge-not-submitted">미제출</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="step-content">
          <span class="badge badge-empty">-</span>
        </div>
      <% end %>
    </td>
  <% end %>
</tr>

<script>
// 드롭다운 메뉴 토글
function toggleProjectMenu(projectId) {
  const menu = document.getElementById('project-menu-' + projectId);
  const isVisible = menu.style.display === 'block';
  
  // 모든 다른 메뉴 닫기
  document.querySelectorAll('.dropdown-menu').forEach(m => {
    m.style.display = 'none';
  });
  
  // 현재 메뉴 토글
  menu.style.display = isVisible ? 'none' : 'block';
  
  // 메뉴 외부 클릭 시 닫기
  if (!isVisible) {
    setTimeout(() => {
      document.addEventListener('click', function closeMenu(e) {
        if (!menu.contains(e.target) && !e.target.closest('.btn-more')) {
          menu.style.display = 'none';
          document.removeEventListener('click', closeMenu);
        }
      });
    }, 0);
  }
}
</script>
