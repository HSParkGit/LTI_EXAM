<div class="project-form-container">
  <div class="form-header">
    <h1>Edit Project</h1>
  </div>

  <% if flash[:error] %>
    <div class="alert alert-danger"><%= flash[:error] %></div>
  <% end %>

  <%= form_with model: @project, url: project_path(@project), method: :patch, local: true, html: { id: 'project-form' } do |form| %>
    <div class="form-card">
      <!-- Project Title -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Project Title</label>
        </div>
        <div class="form-column-right">
          <%= form.text_field :name,
              class: 'input-full',
              placeholder: 'Project Title',
              required: true,
              id: 'project_title' %>
        </div>
      </div>

      <!-- Group Assignment -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Group Assignment</label>
        </div>
        <div class="form-column-right">
          <div class="border-box">
            <div class="checkbox-group">
              <label class="checkbox-label">
                <%= check_box_tag 'has_group_category', '1', true, id: 'has_group_category', disabled: true %>
                <span>This is a Group Assignment</span>
              </label>
            </div>
            <div class="checkbox-group" style="padding-left: 1.5rem;">
              <label class="checkbox-label">
                <%= form.check_box :grade_group_students_individually, id: 'assignment_grade_students_individually' %>
                <span>Assign Grades to Each Student Individually</span>
              </label>
            </div>
            <div class="form-group" style="margin-top: 1rem;">
              <label for="assignment_group_category_id">Group Set</label>
              <% current_group_category_id = @project_data[:assignments].first&.dig('group_category_id') %>
              <%= form.select :group_category_id,
                  options_for_select(@group_categories.map { |gc| [gc['name'] || gc[:name], gc['id'] || gc[:id]] }, current_group_category_id),
                  { include_blank: 'Select a group category' },
                  { class: 'form-select', id: 'assignment_group_category_id' } %>
            </div>
            <div class="new-group-set-wrapper" style="margin-top: 0.5rem;">
              <button type="button" class="btn-secondary" onclick="window.open('<%= @canvas_url %>/courses/<%= @canvas_course_id %>/users#tab-groups', '_blank')">
                New Group Set
              </button>
              <p class="hint-text">그룹 추가 후 이 페이지를 새로고침하세요.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Assignment Group -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Assignment Group</label>
        </div>
        <div class="form-column-right">
          <% current_assignment_group_id = @project_data[:assignments].first&.dig('assignment_group_id') %>
          <%= form.select :assignment_group_id,
              options_for_select(@assignment_groups.map { |ag| [ag['name'] || ag[:name], ag['id'] || ag[:id]] }, current_assignment_group_id),
              { include_blank: 'Select an assignment group' },
              { class: 'form-select', id: 'assignment_group_id' } %>
        </div>
      </div>

      <!-- Existing Steps -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Existing Steps</label>
        </div>
        <div class="form-column-right">
          <div id="existing-steps-container">
            <% @project_data[:assignments].each_with_index do |assignment, index| %>
              <div class="existing-step-row">
                <input type="hidden" name="project[assignments][<%= index %>][id]" value="<%= assignment['id'] %>" />
                <span class="step-name-label">Step <%= index + 1 %></span>
                <input type="text"
                       name="project[assignments][<%= index %>][name]"
                       class="step-name-input"
                       value="<%= assignment['name'] %>"
                       required
                       maxlength="254" />
                <button type="button" class="btn-edit-canvas" onclick="window.open('<%= @canvas_url %>/courses/<%= @canvas_course_id %>/assignments/<%= assignment['id'] %>/edit', '_blank')">
                  Edit in Canvas
                </button>
                <% if @project_data[:assignments].size > 1 %>
                  <button type="button" class="btn-delete-step" onclick="markStepForDeletion(this, <%= index %>)">
                    Delete
                  </button>
                <% end %>
              </div>
            <% end %>
          </div>
          <p class="hint-text">점수, 마감일, 설명 등 상세 설정은 "Edit in Canvas" 버튼을 클릭하세요.</p>
        </div>
      </div>

      <!-- Add New Steps -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Add New Steps</label>
        </div>
        <div class="form-column-right">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
            <input type="number"
                   id="new-step-count"
                   min="0"
                   max="<%= 15 - @project_data[:assignments].size %>"
                   value="0"
                   class="input-full"
                   style="max-width: 80px;" />
            <span class="hint-text" style="margin: 0;">개 추가 (최대 <%= 15 - @project_data[:assignments].size %>개)</span>
          </div>
          <div id="new-steps-container">
            <!-- 동적으로 생성됨 -->
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="window.location.href='<%= project_path(@project) %>'">
          Cancel
        </button>
        <% if @is_published %>
          <button type="submit" name="project[publish]" value="unpublish" class="btn-unpublish">
            Save & Unpublish
          </button>
        <% end %>
        <button type="submit" name="project[publish]" value="false" class="btn-primary">
          Save
        </button>
        <% unless @is_published %>
          <button type="submit" name="project[publish]" value="true" class="btn-publish">
            Save & Publish
          </button>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<style>
  .project-form-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .form-header {
    padding: 20px 0;
  }

  .form-header h1 {
    font-size: 26px;
    font-weight: 500;
    margin: 0;
    color: #212529;
  }

  .form-card {
    background: #fff;
    border: 1px solid #c7cdd1;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .form-row {
    display: flex;
    margin-bottom: 20px;
  }

  .form-column-left {
    width: 180px;
    padding-right: 20px;
    padding-top: 8px;
  }

  .form-column-left label {
    font-weight: 600;
    color: #2d3b45;
    font-size: 14px;
  }

  .form-column-right {
    flex: 1;
  }

  .input-full {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
  }

  .input-full:focus {
    outline: none;
    border-color: #0374B5;
    box-shadow: 0 0 0 2px rgba(3, 116, 181, 0.2);
  }

  .form-select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    background-color: white;
  }

  .border-box {
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    padding: 16px;
    background-color: #fafafa;
  }

  .checkbox-group {
    margin-bottom: 8px;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
  }

  .form-group {
    margin-bottom: 12px;
  }

  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 500;
    font-size: 14px;
    color: #2d3b45;
  }

  .hint-text {
    font-size: 12px;
    color: #6c757d;
    margin-top: 6px;
    margin-bottom: 0;
  }

  .btn-secondary {
    background-color: #f5f5f5;
    color: #2d3b45;
    border: 1px solid #c7cdd1;
    padding: 8px 16px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-secondary:hover {
    background-color: #e6e6e6;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #e9ecef;
  }

  .btn-cancel {
    background-color: transparent;
    color: #6c757d;
    border: 1px solid #c7cdd1;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-cancel:hover {
    background-color: #f8f9fa;
  }

  .btn-primary {
    background-color: #0374B5;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-primary:hover {
    background-color: #025a8c;
  }

  .btn-publish {
    background-color: #0B874B;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-publish:hover {
    background-color: #096b3c;
  }

  .btn-unpublish {
    background-color: #6c757d;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-unpublish:hover {
    background-color: #5a6268;
  }

  /* Existing Step Row */
  .existing-step-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    padding: 10px;
    background-color: #f8f9fa;
    border-radius: 4px;
  }

  .existing-step-row.deleted {
    opacity: 0.5;
    text-decoration: line-through;
  }

  .step-name-label {
    width: 60px;
    font-size: 14px;
    font-weight: 500;
    color: #2d3b45;
    flex-shrink: 0;
  }

  .step-name-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
  }

  .step-name-input:focus {
    outline: none;
    border-color: #0374B5;
    box-shadow: 0 0 0 2px rgba(3, 116, 181, 0.2);
  }

  .btn-edit-canvas {
    background-color: #0374B5;
    color: white;
    border: none;
    padding: 6px 12px;
    font-size: 12px;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-edit-canvas:hover {
    background-color: #025a8c;
  }

  .btn-delete-step {
    background-color: #dc3545;
    color: white;
    border: none;
    padding: 6px 12px;
    font-size: 12px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-delete-step:hover {
    background-color: #c82333;
  }

  .btn-restore-step {
    background-color: #28a745;
    color: white;
    border: none;
    padding: 6px 12px;
    font-size: 12px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-restore-step:hover {
    background-color: #218838;
  }

  /* New Step Row */
  .new-step-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  /* Alert */
  .alert {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .alert-danger {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
  }
</style>

<script>
  const existingStepsCount = <%= @project_data[:assignments].size %>;
  const maxSteps = 15;
  const projectTitleInput = document.getElementById('project_title');
  const newStepCountInput = document.getElementById('new-step-count');
  const newStepsContainer = document.getElementById('new-steps-container');

  // 새 Step 이름 입력 필드 생성
  function renderNewStepInputs() {
    const count = parseInt(newStepCountInput.value) || 0;
    const projectTitle = projectTitleInput.value || 'Step';

    // 기존 값 저장
    const existingValues = {};
    newStepsContainer.querySelectorAll('.new-step-input').forEach((input, index) => {
      existingValues[index] = input.value;
    });

    newStepsContainer.innerHTML = '';

    for (let i = 0; i < count; i++) {
      const row = document.createElement('div');
      row.className = 'new-step-row';

      const stepNumber = existingStepsCount + i + 1;
      const inputIndex = existingStepsCount + i;

      // 기존 값이 있으면 사용, 없으면 기본값 생성
      const defaultValue = existingValues[i] || `${projectTitle}_${stepNumber}`;

      row.innerHTML = `
        <span class="step-name-label">Step ${stepNumber}</span>
        <input type="text"
               name="project[assignments][${inputIndex}][name]"
               class="step-name-input new-step-input"
               value="${defaultValue}"
               required
               maxlength="254"
               placeholder="Step ${stepNumber} 이름" />
      `;

      newStepsContainer.appendChild(row);
    }
  }

  // 새 Step 개수 변경 시
  newStepCountInput.addEventListener('change', function() {
    const maxNew = maxSteps - existingStepsCount;
    let value = parseInt(this.value) || 0;
    if (value < 0) value = 0;
    if (value > maxNew) value = maxNew;
    this.value = value;
    renderNewStepInputs();
  });

  // 프로젝트 제목 변경 시 - 기존에 수정 안 한 새 Step 이름만 업데이트
  projectTitleInput.addEventListener('input', function() {
    const projectTitle = this.value || 'Step';
    const inputs = newStepsContainer.querySelectorAll('.new-step-input');

    inputs.forEach((input, index) => {
      const pattern = /_\d+$/;
      if (pattern.test(input.value)) {
        const stepNumber = existingStepsCount + index + 1;
        input.value = `${projectTitle}_${stepNumber}`;
      }
    });
  });

  // Step 삭제 표시
  function markStepForDeletion(button, index) {
    const row = button.closest('.existing-step-row');

    if (row.classList.contains('deleted')) {
      // 복원
      row.classList.remove('deleted');
      row.querySelector('input[name*="[_destroy]"]')?.remove();
      button.textContent = 'Delete';
      button.className = 'btn-delete-step';
    } else {
      // 삭제 표시
      row.classList.add('deleted');
      const destroyInput = document.createElement('input');
      destroyInput.type = 'hidden';
      destroyInput.name = `project[assignments][${index}][_destroy]`;
      destroyInput.value = 'true';
      row.appendChild(destroyInput);
      button.textContent = 'Restore';
      button.className = 'btn-restore-step';
    }
  }

  // 초기화
  document.addEventListener('DOMContentLoaded', function() {
    renderNewStepInputs();
  });
</script>
