<div class="project-form-container">
  <div class="form-header">
    <h1>Add Project</h1>
  </div>

  <% if flash[:error] %>
    <div class="alert alert-danger"><%= flash[:error] %></div>
  <% end %>

  <%= form_with model: @project, url: projects_path, local: true, html: { id: 'project-form' } do |form| %>
    <div class="form-card">
      <!-- Project Title -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Project Title</label>
        </div>
        <div class="form-column-right">
          <%= form.text_field :name,
              class: 'input-full',
              placeholder: 'Project Title',
              required: true,
              id: 'project_title' %>
        </div>
      </div>

      <!-- Group Assignment -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Group Assignment</label>
        </div>
        <div class="form-column-right">
          <div class="border-box">
            <div class="checkbox-group">
              <label class="checkbox-label">
                <%= check_box_tag 'has_group_category', '1', true, id: 'has_group_category', disabled: true %>
                <span>This is a Group Assignment</span>
              </label>
            </div>
            <div class="checkbox-group" style="padding-left: 1.5rem;">
              <label class="checkbox-label">
                <%= form.check_box :grade_group_students_individually, id: 'assignment_grade_students_individually' %>
                <span>Assign Grades to Each Student Individually</span>
              </label>
            </div>
            <div class="form-group" style="margin-top: 1rem;">
              <label for="assignment_group_category_id">Group Set</label>
              <%= form.select :group_category_id,
                  options_for_select(@group_categories.map { |gc| [gc['name'] || gc[:name], gc['id'] || gc[:id]] }, nil),
                  { include_blank: 'Select a group category' },
                  { class: 'form-select', id: 'assignment_group_category_id' } %>
            </div>
            <div class="new-group-set-wrapper" style="margin-top: 0.5rem;">
              <button type="button" class="btn-secondary" onclick="window.open('<%= @canvas_url %>/courses/<%= @canvas_course_id %>/users#tab-groups', '_blank')">
                New Group Set
              </button>
              <p class="hint-text">그룹 추가 후 이 페이지를 새로고침하세요.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Assignment Group -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Assignment Group</label>
        </div>
        <div class="form-column-right">
          <%= form.select :assignment_group_id,
              options_for_select(@assignment_groups.map { |ag| [ag['name'] || ag[:name], ag['id'] || ag[:id]] }, nil),
              { include_blank: 'Select an assignment group' },
              { class: 'form-select', id: 'assignment_group_id' } %>
        </div>
      </div>

      <!-- Number of Steps -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Number of Steps</label>
        </div>
        <div class="form-column-right">
          <input type="number"
                 id="step-count"
                 min="1"
                 max="15"
                 value="1"
                 class="input-full"
                 style="max-width: 120px;" />
          <p class="hint-text">최대 15개까지 생성 가능합니다.</p>
        </div>
      </div>

      <!-- Step Names -->
      <div class="form-row">
        <div class="form-column-left">
          <label>Step Names</label>
        </div>
        <div class="form-column-right">
          <div id="step-names-container">
            <!-- 동적으로 생성됨 -->
          </div>
          <p class="hint-text">점수, 마감일 등 상세 설정은 생성 후 Canvas에서 편집하세요.</p>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="window.location.href='<%= projects_path %>'">
          Cancel
        </button>
        <button type="submit" name="project[publish]" value="false" class="btn-primary">
          Save
        </button>
        <button type="submit" name="project[publish]" value="true" class="btn-publish">
          Save & Publish
        </button>
      </div>
    </div>
  <% end %>
</div>

<style>
  .project-form-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .form-header {
    padding: 20px 0;
  }

  .form-header h1 {
    font-size: 26px;
    font-weight: 500;
    margin: 0;
    color: #212529;
  }

  .form-card {
    background: #fff;
    border: 1px solid #c7cdd1;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .form-row {
    display: flex;
    margin-bottom: 20px;
  }

  .form-column-left {
    width: 180px;
    padding-right: 20px;
    padding-top: 8px;
  }

  .form-column-left label {
    font-weight: 600;
    color: #2d3b45;
    font-size: 14px;
  }

  .form-column-right {
    flex: 1;
  }

  .input-full {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
  }

  .input-full:focus {
    outline: none;
    border-color: #0374B5;
    box-shadow: 0 0 0 2px rgba(3, 116, 181, 0.2);
  }

  .form-select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
    background-color: white;
  }

  .border-box {
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    padding: 16px;
    background-color: #fafafa;
  }

  .checkbox-group {
    margin-bottom: 8px;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
  }

  .form-group {
    margin-bottom: 12px;
  }

  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 500;
    font-size: 14px;
    color: #2d3b45;
  }

  .hint-text {
    font-size: 12px;
    color: #6c757d;
    margin-top: 6px;
    margin-bottom: 0;
  }

  .btn-secondary {
    background-color: #f5f5f5;
    color: #2d3b45;
    border: 1px solid #c7cdd1;
    padding: 8px 16px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-secondary:hover {
    background-color: #e6e6e6;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #e9ecef;
  }

  .btn-cancel {
    background-color: transparent;
    color: #6c757d;
    border: 1px solid #c7cdd1;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-cancel:hover {
    background-color: #f8f9fa;
  }

  .btn-primary {
    background-color: #0374B5;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-primary:hover {
    background-color: #025a8c;
  }

  .btn-publish {
    background-color: #0B874B;
    color: white;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-publish:hover {
    background-color: #096b3c;
  }

  /* Step Name Input */
  .step-name-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .step-name-label {
    width: 60px;
    font-size: 14px;
    font-weight: 500;
    color: #2d3b45;
  }

  .step-name-input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid #c7cdd1;
    border-radius: 4px;
    font-size: 14px;
  }

  .step-name-input:focus {
    outline: none;
    border-color: #0374B5;
    box-shadow: 0 0 0 2px rgba(3, 116, 181, 0.2);
  }

  /* Alert */
  .alert {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .alert-danger {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
  }
</style>

<script>
  const projectTitleInput = document.getElementById('project_title');
  const stepCountInput = document.getElementById('step-count');
  const stepNamesContainer = document.getElementById('step-names-container');

  // Step 이름 입력 필드 생성
  function renderStepNameInputs() {
    const count = parseInt(stepCountInput.value) || 1;
    const projectTitle = projectTitleInput.value || 'Step';

    // 기존 값 저장
    const existingValues = {};
    stepNamesContainer.querySelectorAll('.step-name-input').forEach((input, index) => {
      existingValues[index] = input.value;
    });

    stepNamesContainer.innerHTML = '';

    for (let i = 0; i < count; i++) {
      const row = document.createElement('div');
      row.className = 'step-name-row';

      // 기존 값이 있으면 사용, 없으면 기본값 생성
      const defaultValue = existingValues[i] || `${projectTitle}_${i + 1}`;

      row.innerHTML = `
        <span class="step-name-label">Step ${i + 1}</span>
        <input type="text"
               name="project[assignments][${i}][name]"
               class="step-name-input"
               value="${defaultValue}"
               required
               maxlength="254"
               placeholder="Step ${i + 1} 이름" />
      `;

      stepNamesContainer.appendChild(row);
    }
  }

  // Step 개수 변경 시
  stepCountInput.addEventListener('change', function() {
    let value = parseInt(this.value) || 1;
    if (value < 1) value = 1;
    if (value > 15) value = 15;
    this.value = value;
    renderStepNameInputs();
  });

  // 프로젝트 제목 변경 시 - 기존에 수정 안 한 Step 이름만 업데이트
  projectTitleInput.addEventListener('input', function() {
    const projectTitle = this.value || 'Step';
    const inputs = stepNamesContainer.querySelectorAll('.step-name-input');

    inputs.forEach((input, index) => {
      // 기본 패턴(이전제목_숫자)과 일치하면 새 제목으로 업데이트
      const pattern = /_\d+$/;
      if (pattern.test(input.value)) {
        input.value = `${projectTitle}_${index + 1}`;
      }
    });
  });

  // 초기화
  document.addEventListener('DOMContentLoaded', function() {
    renderStepNameInputs();
  });
</script>
